NODE_ENV=development
PORT=5000

# MongoDB Atlas Connection
MONGO_URI=your_mongodb_connection_string_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL
CLIENT_URL=http://localhost:5173

# Currency & Subscription Settings
CURRENCY=INR
MONTHLY_PLAN_AMOUNT=1000
YEARLY_PLAN_AMOUNT=10000
PRIZE_POOL_PERCENTAGE=50
MIN_CHARITY_PERCENTAGE=10

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Digital Heroes <noreply@digitalheroes.local>